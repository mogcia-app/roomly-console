rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return isSignedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : "";
    }

    function hotelId() {
      return isSignedIn() && request.auth.token.hotel_id is string
        ? request.auth.token.hotel_id
        : "";
    }

    function isFrontRole() {
      return role() in ["hotel_front", "hotel_admin"];
    }

    function belongsToHotel(resourceHotelId) {
      return resourceHotelId is string && resourceHotelId == hotelId();
    }

    function belongsToHotelResource(resourceData) {
      return belongsToHotel(resourceData.hotel_id) || belongsToHotel(resourceData.hotelId);
    }

    function resourceThreadId(resourceData) {
      return resourceData.thread_id is string
        ? resourceData.thread_id
        : resourceData.threadId is string
          ? resourceData.threadId
          : "";
    }

    function resourceHotelId(resourceData) {
      return resourceData.hotel_id is string
        ? resourceData.hotel_id
        : resourceData.hotelId is string
          ? resourceData.hotelId
          : "";
    }

    function hasOnlyChangedKeys(allowedKeys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(allowedKeys);
    }

    match /chat_threads/{threadId} {
      allow read: if isFrontRole() && belongsToHotelResource(resource.data);
      allow create, delete: if false;
      allow update: if isFrontRole()
        && belongsToHotelResource(resource.data)
        && resourceHotelId(request.resource.data) == resourceHotelId(resource.data);
    }

    match /messages/{messageId} {
      allow read: if isFrontRole()
        && exists(/databases/$(database)/documents/chat_threads/$(resourceThreadId(resource.data)))
        && belongsToHotel(
          resourceHotelId(
            get(/databases/$(database)/documents/chat_threads/$(resourceThreadId(resource.data))).data
          )
        );

      allow create: if isFrontRole()
        && request.resource.data.sender == "front"
        && resourceThreadId(request.resource.data) != ""
        && exists(/databases/$(database)/documents/chat_threads/$(resourceThreadId(request.resource.data)))
        && belongsToHotel(
          resourceHotelId(
            get(/databases/$(database)/documents/chat_threads/$(resourceThreadId(request.resource.data))).data
          )
        );

      allow update, delete: if false;
    }

    match /rooms/{roomId} {
      allow read: if isFrontRole() && belongsToHotelResource(resource.data);
      allow write: if false;
    }

    match /stays/{stayId} {
      allow read: if isFrontRole() && belongsToHotelResource(resource.data);
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if isFrontRole()
        && (
          request.auth.uid == uid
          || (role() == "hotel_admin" && belongsToHotel(resourceHotelId(resource.data)))
        );
      allow write: if false;
    }
  }
}
